# ─────────────────────────────────────────────────────────────────────
# Document Extractor — environment variables
#
# All variables here are optional unless flagged REQUIRED.
# Copy this file to a local `.env.local` (gitignored) and fill in values.
# Defaults are documented in docs/TECH_STACK.md and apply when a value
# is absent or empty.
# ─────────────────────────────────────────────────────────────────────

# ── Anthropic vision fallback (optional) ─────────────────────────────
# If absent, the signature heuristic runs without a vision-model second
# pass. Detections below 0.6 confidence will surface as "unverified"
# in the UI; this is not an error.
ANTHROPIC_API_KEY=

# Maximum dollar budget per request for vision fallback calls.
# Default: 0.05 (~16 Claude Sonnet vision calls at current pricing).
VISION_BUDGET_USD_PER_REQUEST=

# Claude model used for signature verification.
# Default: claude-sonnet-4-6
VISION_MODEL=

# ── Processing limits ────────────────────────────────────────────────
# Hard upload size limit in bytes.  Default: 26214400 (25 MB).
MAX_UPLOAD_BYTES=

# Hard page count limit per document.  Default: 50.
MAX_PAGES=

# Hard batch size limit.  Default: 10.
MAX_BATCH_FILES=

# Hard per-job timeout in seconds.  Default: 60.
JOB_TIMEOUT_SECONDS=

# Concurrency for heavy operations (LibreOffice, Tesseract).
# Default: 2.  Raise carefully on multi-core machines.
HEAVY_CONCURRENCY=

# Maximum queue depth before 503 SERVICE_BUSY is returned.
# Default: 10.
MAX_QUEUE_DEPTH=

# Rasterization DPI.  Default: 200 (sweet spot for signature fidelity
# vs memory).
RASTER_DPI=

# ── Temp file lifecycle ──────────────────────────────────────────────
# Per-request temp dirs live under this prefix.
# Default: os.tmpdir().  Override for tests or alternate disks.
TEMP_DIR=

# How often the background sweeper runs (seconds).  Default: 300.
SWEEP_INTERVAL_SECONDS=

# Temp dirs older than this are deleted by the sweeper (seconds).
# Default: 600 (10 minutes).
TEMP_TTL_SECONDS=

# ── Logging ──────────────────────────────────────────────────────────
# pino log level: trace | debug | info | warn | error | fatal
# Default: info.
LOG_LEVEL=

# ── Next.js / Node ───────────────────────────────────────────────────
# Set by Next at build/run time; documented here for completeness.
NODE_ENV=
